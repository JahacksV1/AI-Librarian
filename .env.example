# Copy this file to .env and do not edit .env.example directly.
#
# IMPORTANT:
#   The URLs below use Docker service names (postgres, ollama) — NOT localhost.
#   These are the correct values for running inside Docker Compose.
#   If you ever run the backend directly outside Docker, swap to localhost URLs.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://aijah:aijah@postgres:5432/aijah

# --- Model Provider ---
# Which LLM provider to use. Values: ollama, anthropic, openai
MODEL_PROVIDER=ollama

# Override the default model name for the active provider.
# Leave blank to use the provider's default:
#   ollama    → qwen2.5
#   anthropic → claude-sonnet-4-20250514
#   openai    → gpt-4o
MODEL_NAME=

# --- API Keys (required only when using that provider) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Ollama (used when MODEL_PROVIDER=ollama) ---
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5

# --- Sandbox ---
# Path the MCP server is allowed to scan and modify.
# The MCP server runs natively (not in Docker), so this must be a real path on your machine.
#
# For testing with the bundled sandbox folder:
#   Windows:   SANDBOX_ROOT=C:/Users/<you>/aijah/sandbox
#   Mac/Linux: SANDBOX_ROOT=/path/to/aijah/sandbox
#
# To scan your real computer, change to your home directory:
#   Windows:   SANDBOX_ROOT=C:/Users/<you>
#   Mac/Linux: SANDBOX_ROOT=/Users/<you>
SANDBOX_ROOT=C:/Users/<your-username>/aijah/sandbox

# --- MCP ---
MCP_MOUNT_PATH=/mcp
# The MCP server runs natively on the host (scripts/start-mcp.ps1 or start-mcp.sh).
# The Docker backend connects to it via host.docker.internal — set automatically by docker-compose.
# Leave blank only if running both backend and MCP in-process for local dev without Docker.
MCP_URL=http://host.docker.internal:8001/mcp

# --- HTTP (optional) ---
# Comma-separated browser origins allowed to call the API (CORS). Needed if the UI
# dev server uses a different origin than the API and you are not using a reverse proxy.
# Example: http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=
